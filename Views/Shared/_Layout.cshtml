@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyShare</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Outfit:wght@700&display=swap" rel="stylesheet" />

    <style>
        :root {
            --bg-blue: #f0f7ff;
            --dot-color: #cbd5e1;
            --main-blue: #2563eb;
            --text-dark: #0f172a;
            --nav-height: 85px;
        }

        body {
            background-color: var(--bg-blue) !important;
            /* HỌA TIẾT CHẤM BI TOÀN TRANG */
            background-image: radial-gradient(var(--dot-color) 1.2px, transparent 1.2px) !important;
            background-size: 25px 25px !important;
            background-attachment: fixed !important;
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        /* NAVBAR KHUNG TRÊN */
        .main-header {
            height: var(--nav-height);
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid #e2e8f0;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
        }

        .nav-container {
            width: 100%;
            max-width: 1400px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        .logo-brand {
            font-family: 'Outfit', sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--main-blue);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links {
            display: flex;
            gap: 5px;
            align-items: center;
        }

        /* STYLE ICON & CHỮ TRONG MENU */
        .nav-custom-link {
            padding: 10px 15px;
            border-radius: 12px;
            color: #64748b;
            text-decoration: none;
            font-weight: 700; /* Chữ đậm rõ nét */
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .nav-custom-link i {
            font-size: 1.25rem;
            color: var(--main-blue); /* Icon luôn có màu xanh nổi bật */
        }

        .nav-custom-link:hover {
            background: #f1f5f9;
            color: var(--main-blue);
        }

        .nav-custom-link.active {
            background: var(--main-blue);
            color: #ffffff !important;
        }

        .nav-custom-link.active i {
            color: #ffffff; /* Icon trắng khi menu active */
        }

        /* AUTH BUTTONS */
        .btn-register-header {
            background: var(--main-blue);
            color: white !important;
            font-weight: 700;
            padding: 10px 22px;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
            text-decoration: none;
        }

        /* ===== CSS CHO DROPDOWN ADMIN MỚI THÊM ===== */
        .admin-drop-item {
            font-weight: 600;
            color: #475569;
            padding: 10px 15px;
            border-radius: 8px;
            transition: all 0.2s ease;
            margin-bottom: 2px;
        }

        .admin-drop-item:hover {
            background-color: #f1f5f9;
            color: #2563eb;
            transform: translateX(4px);
        }

        .admin-drop-item.text-danger:hover {
            background-color: #fee2e2 !important;
            color: #ef4444 !important;
        }

        .dropdown-menu {
            animation: slideIn 0.2s ease-out;
        }

        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        /* ========================================= */

        .main-content {
            margin-top: var(--nav-height);
            padding: 40px 0;
        }

        .content-container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Tiêu đề trang đậm đà */
        .page-title-bold {
            font-weight: 800 !important;
            color: var(--text-dark);
            letter-spacing: -0.5px;
        }
    </style>
</head>
<body>

    <header class="main-header shadow-sm">
        <div class="nav-container">
            <a class="logo-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-intersect"></i> StudyShare
            </a>

            <nav class="nav-links d-none d-xl-flex">
                <a class="nav-custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i> Thư viện
                </a>
                
                <a class="nav-custom-link" asp-area="User" asp-controller="Chat" asp-action="Index">
                    <i class="bi bi-cpu-fill"></i> Trợ lí AI
                </a>
                
                <a class="nav-custom-link" asp-area="User" asp-controller="Question" asp-action="Index">
                    <i class="bi bi-chat-square-text-fill"></i> Thảo luận
                </a>
                
                <a class="nav-custom-link" asp-area="User" asp-controller="Ranking" asp-action="Index">
                    <i class="bi bi-trophy-fill"></i> Bảng vàng
                </a>

                @if (SignInManager.IsSignedIn(User))
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="dropdown">
                            <a class="nav-custom-link dropdown-toggle" href="#" role="button" id="adminMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false" 
                               style="background-color: #eff6ff; color: #2563eb;">
                                <i class="bi bi-shield-lock-fill"></i> Quản trị
                            </a>
                            
                            <ul class="dropdown-menu shadow-lg border-0 rounded-4 mt-3 p-2" aria-labelledby="adminMenuDropdown" style="min-width: 240px;">
                                <li>
                                    <div class="dropdown-header text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Menu Quản Trị</div>
                                </li>
                                <li>
                                    <a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                        <i class="bi bi-speedometer2 me-2 text-primary"></i> Dashboard
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="User" asp-action="Index">
                                        <i class="bi bi-people-fill me-2 text-secondary"></i> Người dùng
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Document" asp-action="Index">
                                        <i class="bi bi-file-earmark-text-fill me-2 text-secondary"></i> Tài liệu
                                    </a>
                                </li>
                               <li>
    <a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Question" asp-action="Index">
        <i class="bi bi-chat-square-dots-fill me-2" style="color: #0ea5e9;"></i> Thảo luận
    </a>
</li>

<li>
    <a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Answer" asp-action="Index">
        <i class="bi bi-reply-all-fill me-2" style="color: #8b5cf6;"></i> Bình luận
    </a>
</li>
                                <li>
                                    <a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Category" asp-action="Index">
                                        <i class="bi bi-tags-fill me-2 text-secondary"></i> Danh mục
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider my-2"></li>
                                <li>
    <a class="dropdown-item admin-drop-item text-danger fw-bold" asp-area="Admin" asp-controller="User" asp-action="PendingReports" style="background-color: #fef2f2;">
        <i class="bi bi-flag-fill me-2"></i> Báo cáo vi phạm
    </a>
</li>
                            </ul>
                        </div>
                        }
                    else
                    {
                        <a class="nav-custom-link" asp-area="User" asp-controller="Document" asp-action="Create">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Tải lên
                        </a>
                    }
                }
            </nav>

            <div class="auth-group d-flex align-items-center gap-3">
                @if (!SignInManager.IsSignedIn(User))
                {
                    <a class="nav-custom-link d-none d-sm-flex" asp-area="" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-person-circle"></i> Đăng nhập
                    </a>
                    <a class="btn-register-header" asp-area="" asp-controller="Account" asp-action="Register">
                        Đăng ký ngay
                    </a>
                }
                else
                {
                    <partial name="_LoginPartial" />
                }
            </div>
        </div>
    </header>

    <main class="main-content">
        <div class="content-container">
            
            @if (TempData["Success"] != null || TempData["success"] != null || TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 rounded-4 d-flex align-items-center mb-4" role="alert" style="background-color: #d1fae5; color: #065f46;">
                    <i class="bi bi-check-circle-fill fs-5 me-3"></i>
                    <div class="fw-medium">
                        @(TempData["Success"] ?? TempData["success"] ?? TempData["SuccessMessage"])
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["Error"] != null || TempData["error"] != null || TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 rounded-4 d-flex align-items-center mb-4" role="alert" style="background-color: #fee2e2; color: #991b1b;">
                    <i class="bi bi-exclamation-triangle-fill fs-5 me-3"></i>
                    <div class="fw-medium">
                        @(TempData["Error"] ?? TempData["error"] ?? TempData["ErrorMessage"])
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @RenderBody()
        </div>
    </main>

    <footer class="py-5 text-center">
        <p class="text-muted small">© 2026 <b>StudyShare</b> — Hệ thống chia sẻ tài liệu thông minh</p>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* --- GIỮ NGUYÊN LOGIC MODAL BANNED --- *@
    @if (User.Identity.IsAuthenticated)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null && (currentUser.WarningCount >= 3 || currentUser.IsBanned))
        {
            <div class="modal fade" id="violationModal" data-bs-backdrop="static">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg rounded-5">
                        <div class="modal-body text-center py-5">
                            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem"></i>
                            <h3 class="fw-bold mt-3">TÀI KHOẢN BỊ KHÓA</h3>
                            <p class="text-muted">Tài khoản vi phạm chính sách cộng đồng.</p>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-danger rounded-pill px-5">ĐĂNG XUẤT</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    new bootstrap.Modal(document.getElementById('violationModal')).show();
                });
            </script>
        }
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
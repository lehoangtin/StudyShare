@model StudyShare.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    .login-container { min-height: calc(100vh - 150px); display: flex; align-items: center; }
    .bg-glass { background: rgba(37, 99, 235, 0.75); backdrop-filter: blur(10px); }
    .btn-login { transition: all 0.3s; background: linear-gradient(135deg, #1e3a8a, #2563eb); border: none; }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); }
</style>

<div class="container login-container py-5">
    <div class="card shadow-lg border-0 rounded-5 overflow-hidden w-100" style="max-width: 1000px; margin: 0 auto;">
        <div class="row g-0 h-100">
            <div class="col-lg-6 d-none d-lg-block position-relative" style="background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop') center/cover;">
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-glass d-flex flex-column justify-content-center align-items-center text-center p-5">
                    <i class="bi bi-intersect text-white mb-3" style="font-size: 4rem;"></i>
                    <h2 class="fw-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">StudyShare</h2>
                    <p class="text-white-50 fs-5">Nền tảng chia sẻ tri thức và hỗ trợ học tập dành cho sinh viên Bách Khoa.</p>
                </div>
            </div>

            <div class="col-lg-6 bg-white p-5 p-lg-5 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark mb-1">Chào mừng trở lại! 👋</h3>
                    <p class="text-muted">Đăng nhập để tiếp tục chia sẻ tài liệu</p>
                </div>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control rounded-4 bg-light border-0" placeholder="name@example.com" />
                        <label asp-for="Email"><i class="bi bi-envelope-fill me-2 text-muted"></i>Email của bạn</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="Password" type="password" class="form-control rounded-4 bg-light border-0" placeholder="Mật khẩu" />
                        <label asp-for="Password"><i class="bi bi-lock-fill me-2 text-muted"></i>Mật khẩu</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMe">
                            <label class="form-check-label text-muted" for="rememberMe">Nhớ mật khẩu</label>
                        </div>
                        <a asp-action="ForgotPassword" class="text-decoration-none fw-bold small" style="color: #2563eb;">Quên mật khẩu?</a>
                    </div>

                    <button type="submit" class="btn btn-login btn-primary w-100 rounded-pill py-3 fw-bold text-uppercase mb-3">
                        Đăng Nhập
                    </button>
                    
                    <div class="text-center text-muted small">
                        Chưa có tài khoản? <a asp-action="Register" class="fw-bold text-decoration-none" style="color: #2563eb;">Đăng ký ngay</a>
                    </div>
                    <div class="text-center text-muted small">
                        Chưa nhận được link kích hoạt? <a asp-action="ResendEmailConfirmation" class="fw-bold text-decoration-none" style="color: #2563eb;">Gửi lại email</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
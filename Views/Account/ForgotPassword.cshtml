@model StudyShare.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<style>
    .login-container { min-height: calc(100vh - 150px); display: flex; align-items: center; }
    .bg-glass { background: rgba(37, 99, 235, 0.75); backdrop-filter: blur(10px); }
    .btn-login { transition: all 0.3s; background: linear-gradient(135deg, #1e3a8a, #2563eb); border: none; }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); }
</style>

<div class="container login-container py-5">
    <div class="card shadow-lg border-0 rounded-5 overflow-hidden w-100" style="max-width: 1000px; margin: 0 auto;">
        <div class="row g-0 h-100">
            <div class="col-lg-6 d-none d-lg-block position-relative" style="background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop') center/cover;">
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-glass d-flex flex-column justify-content-center align-items-center text-center p-5">
                    <i class="bi bi-shield-lock text-white mb-3" style="font-size: 4rem;"></i>
                    <h2 class="fw-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Bảo Mật Tài Khoản</h2>
                    <p class="text-white-50 fs-5">Khôi phục quyền truy cập vào tài khoản StudyShare của bạn nhanh chóng và an toàn.</p>
                </div>
            </div>

            <div class="col-lg-6 bg-white p-5 p-lg-5 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark mb-1">Quên mật khẩu? 🔑</h3>
                    <p class="text-muted">Nhập email của bạn để nhận liên kết đặt lại mật khẩu</p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="Email" class="form-control rounded-4 bg-light border-0" placeholder="name@example.com" />
                        <label asp-for="Email"><i class="bi bi-envelope-fill me-2 text-muted"></i>Email của bạn</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-login btn-primary text-white w-100 rounded-pill py-3 fw-bold text-uppercase mb-3" style="color: #ffffff !important;">
                        Gửi Yêu Cầu Khôi Phục
                    </button>
                    
                    <div class="text-center text-muted small mt-3">
                        Nhớ ra mật khẩu rồi? <a asp-action="Login" class="fw-bold text-decoration-none" style="color: #2563eb;">Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
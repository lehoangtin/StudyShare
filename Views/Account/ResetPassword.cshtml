@model StudyShare.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<style>
    .login-container { min-height: calc(100vh - 150px); display: flex; align-items: center; }
    .bg-glass { background: rgba(37, 99, 235, 0.75); backdrop-filter: blur(10px); }
    .btn-login { transition: all 0.3s; background: linear-gradient(135deg, #1e3a8a, #2563eb); border: none; }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); }
</style>

<div class="container login-container py-5">
    <div class="card shadow-lg border-0 rounded-5 overflow-hidden w-100" style="max-width: 1000px; margin: 0 auto;">
        <div class="row g-0 h-100">
            <div class="col-lg-6 d-none d-lg-block position-relative" style="background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop') center/cover;">
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-glass d-flex flex-column justify-content-center align-items-center text-center p-5">
                    <i class="bi bi-key text-white mb-3" style="font-size: 4rem;"></i>
                    <h2 class="fw-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Đặt Lại Mật Khẩu</h2>
                    <p class="text-white-50 fs-5">Tạo một mật khẩu mới mạnh mẽ để bảo vệ tài khoản StudyShare của bạn.</p>
                </div>
            </div>

            <div class="col-lg-6 bg-white p-5 p-lg-5 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark mb-1">Mật khẩu mới 🔒</h3>
                    <p class="text-muted">Vui lòng thiết lập mật khẩu của bạn</p>
                </div>

                <form asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <input type="hidden" asp-for="Email" />
                    <input type="hidden" asp-for="Token" />

                    <div class="form-floating mb-3">
                        <input asp-for="NewPassword" type="password" class="form-control rounded-4 bg-light border-0" placeholder="Mật khẩu mới" />
                        <label asp-for="NewPassword"><i class="bi bi-lock-fill me-2 text-muted"></i>Mật khẩu mới</label>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" type="password" class="form-control rounded-4 bg-light border-0" placeholder="Xác nhận mật khẩu" />
                        <label asp-for="ConfirmPassword"><i class="bi bi-shield-lock-fill me-2 text-muted"></i>Xác nhận mật khẩu</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-login btn-primary w-100 rounded-pill py-3 fw-bold text-uppercase mb-3">
                        Lưu Mật Khẩu Mới
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model StudyShare.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<style>
    .login-container { min-height: calc(100vh - 150px); display: flex; align-items: center; }
    .bg-glass { background: rgba(37, 99, 235, 0.75); backdrop-filter: blur(10px); }
    .btn-login { transition: all 0.3s; background: linear-gradient(135deg, #1e3a8a, #2563eb); border: none; }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3); }
</style>

<div class="container login-container py-5">
    <div class="card shadow-lg border-0 rounded-5 overflow-hidden w-100" style="max-width: 1000px; margin: 0 auto;">
        <div class="row g-0 h-100">
            <div class="col-lg-6 d-none d-lg-block position-relative" style="background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop') center/cover;">
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-glass d-flex flex-column justify-content-center align-items-center text-center p-5">
                    <i class="bi bi-intersect text-white mb-3" style="font-size: 4rem;"></i>
                    <h2 class="fw-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">StudyShare</h2>
                    <p class="text-white-50 fs-5">Tham gia cộng đồng sinh viên Bách Khoa ngay hôm nay để chia sẻ và nhận tài liệu học tập.</p>
                </div>
            </div>

            <div class="col-lg-6 bg-white p-4 p-lg-5 d-flex flex-column justify-content-center">
                <div class="text-center mb-4">
                    <h3 class="fw-bold text-dark mb-1">Tạo tài khoản mới 🚀</h3>
                    <p class="text-muted">Điền thông tin để gia nhập StudyShare</p>
                </div>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="FullName" class="form-control rounded-4 bg-light border-0" placeholder="Nguyễn Văn A" />
                        <label asp-for="FullName"><i class="bi bi-person-fill me-2 text-muted"></i>Họ và tên</label>
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control rounded-4 bg-light border-0" placeholder="name@example.com" />
                        <label asp-for="Email"><i class="bi bi-envelope-fill me-2 text-muted"></i>Email</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Password" type="password" class="form-control rounded-4 bg-light border-0 pe-5" placeholder="Mật khẩu" id="registerPassword" />
                        <label asp-for="Password"><i class="bi bi-lock-fill me-2 text-muted"></i>Mật khẩu</label>
                        <i class="bi bi-eye-slash-fill position-absolute top-50 translate-middle-y end-0 me-3 text-muted" id="toggleRegisterPassword" style="cursor: pointer; z-index: 10;"></i>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4 position-relative">
                        <input asp-for="ConfirmPassword" type="password" class="form-control rounded-4 bg-light border-0 pe-5" placeholder="Xác nhận mật khẩu" id="registerConfirmPassword" />
                        <label asp-for="ConfirmPassword"><i class="bi bi-shield-lock-fill me-2 text-muted"></i>Xác nhận mật khẩu</label>
                        <i class="bi bi-eye-slash-fill position-absolute top-50 translate-middle-y end-0 me-3 text-muted" id="toggleRegisterConfirmPassword" style="cursor: pointer; z-index: 10;"></i>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-login btn-primary text-white w-100 rounded-pill py-3 fw-bold text-uppercase mb-3" style="color: #ffffff !important;">
                        Đăng Ký Ngay
                    </button>
                    
                    <div class="text-center text-muted small">
                        Đã có tài khoản? <a asp-action="Login" class="fw-bold text-decoration-none" style="color: #2563eb;">Đăng nhập</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function setupPasswordToggle(toggleId, inputId) {
            document.getElementById(toggleId).addEventListener('click', function (e) {
                const passwordInput = document.getElementById(inputId);
                const type = passwordInput.getAttribute('type') === 'password' ? 'text' : 'password';
                passwordInput.setAttribute('type', type);
                this.classList.toggle('bi-eye-fill');
                this.classList.toggle('bi-eye-slash-fill');
            });
        }
        setupPasswordToggle('toggleRegisterPassword', 'registerPassword');
        setupPasswordToggle('toggleRegisterConfirmPassword', 'registerConfirmPassword');
    </script>
}
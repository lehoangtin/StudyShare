@{
    ViewData["Title"] = "Xác thực thất bại";
}

<style>
    .login-container { min-height: calc(100vh - 150px); display: flex; align-items: center; }
    .bg-glass { background: rgba(220, 38, 38, 0.85); backdrop-filter: blur(10px); } /* Màu đỏ tươi cho thông báo lỗi */
    .btn-login { transition: all 0.3s; background: linear-gradient(135deg, #dc2626, #b91c1c); border: none; color: white; }
    .btn-login:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(220, 38, 38, 0.3); color: white; }
    .btn-outline-custom { border: 2px solid #e2e8f0; color: #475569; transition: all 0.3s; }
    .btn-outline-custom:hover { background-color: #f1f5f9; color: #0f172a; }
</style>

<div class="container login-container py-5">
    <div class="card shadow-lg border-0 rounded-5 overflow-hidden w-100" style="max-width: 1000px; margin: 0 auto;">
        <div class="row g-0 h-100">
            <div class="col-lg-6 d-none d-lg-block position-relative" style="background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1000&auto=format&fit=crop') center/cover;">
                <div class="position-absolute top-0 start-0 w-100 h-100 bg-glass d-flex flex-column justify-content-center align-items-center text-center p-5">
                    <i class="bi bi-shield-x text-white mb-3" style="font-size: 4rem;"></i>
                    <h2 class="fw-bold text-white mb-3" style="font-family: 'Outfit', sans-serif;">Oops! Có lỗi xảy ra</h2>
                    <p class="text-white-50 fs-5">Rất tiếc, chúng tôi không thể xác thực tài khoản của bạn vào lúc này.</p>
                </div>
            </div>

            <div class="col-lg-6 bg-white p-5 p-lg-5 d-flex flex-column justify-content-center text-center">
                <i class="bi bi-x-circle-fill text-danger mb-3" style="font-size: 5rem;"></i>
                <h3 class="fw-bold text-dark mb-3">Xác thực thất bại</h3>
                <p class="text-muted mb-4" style="font-size: 1.1rem; line-height: 1.6;">
                    Liên kết xác nhận của bạn có thể đã <b>hết hạn</b> hoặc <b>không hợp lệ</b>. Vui lòng yêu cầu hệ thống gửi lại một liên kết mới để tiếp tục.
                </p>

                <div class="d-flex flex-column gap-3">
                    <a asp-action="ResendEmailConfirmation" class="btn btn-login w-100 rounded-pill py-3 fw-bold text-uppercase">
                        Gửi Lại Email Kích Hoạt
                    </a>
                    
                    <a asp-action="Login" class="btn btn-outline-custom w-100 rounded-pill py-3 fw-bold text-uppercase">
                        Quay lại Đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
@model StudyShare.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="container mt-5 mb-5" style="max-width: 600px;">
    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 text-center">
            <i class="bi bi-shield-lock text-primary mb-2" style="font-size: 3rem;"></i>
            <h3 class="fw-bold text-dark mb-0">Đổi Mật Khẩu</h3>
            <p class="text-muted mt-2">Bảo mật tài khoản của bạn</p>
        </div>
        
        <div class="card-body p-4 p-md-5">
            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 text-center"></div>

                <div class="form-floating mb-3">
                    <input asp-for="OldPassword" type="password" class="form-control rounded-4 bg-light border-0" placeholder="Mật khẩu hiện tại" />
                    <label asp-for="OldPassword"><i class="bi bi-key-fill me-2 text-muted"></i>Mật khẩu hiện tại</label>
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="NewPassword" type="password" class="form-control rounded-4 bg-light border-0" placeholder="Mật khẩu mới" />
                    <label asp-for="NewPassword"><i class="bi bi-lock-fill me-2 text-muted"></i>Mật khẩu mới</label>
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="ConfirmPassword" type="password" class="form-control rounded-4 bg-light border-0" placeholder="Xác nhận mật khẩu mới" />
                    <label asp-for="ConfirmPassword"><i class="bi bi-shield-check me-2 text-muted"></i>Xác nhận lại mật khẩu</label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a href="javascript:history.back()" class="btn btn-light rounded-pill px-4 fw-bold">Hủy</a>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-sm" style="background-color: #2563eb;">
                        Cập Nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
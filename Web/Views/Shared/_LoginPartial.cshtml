@using Microsoft.AspNetCore.Identity
@using StudyShare.Models 
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    
    <div class="d-flex flex-row align-items-center gap-3">
        
        <div class="d-flex align-items-center bg-white rounded-pill px-3 py-1 shadow-sm border" style="border-color: #e2e8f0 !important;">
            <span class="badge rounded-pill bg-warning text-dark me-2 fs-6">
                <i class="bi bi-coin text-warning-emphasis"></i> @(user?.Points ?? 0)
            </span>
            <span class="text-dark fw-bold small mb-0">
                Chào, @(User.Identity?.Name ?? "User")
            </span>
        </div>

        <a asp-area="User" asp-controller="User" asp-action="Profile" 
           class="d-flex align-items-center text-decoration-none fw-bold px-3 py-2 rounded-pill transition-all bg-light text-primary border"
           style="border-color: #e2e8f0 !important;">
            <i class="bi bi-person-fill me-1"></i> Profile
        </a>

        <form class="m-0 p-0 d-flex align-items-center" asp-area="" asp-controller="Account" asp-action="Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="btn text-danger fw-bold rounded-pill px-3 py-2 shadow-sm transition-all d-flex align-items-center" 
                    style="background-color: #fee2e2; border: 1px solid #fca5a5;">
                Logout <i class="bi bi-box-arrow-right ms-2"></i>
            </button>
        </form>
        
    </div>
}
else
{
    <div class="d-flex align-items-center gap-3">
        <a class="text-decoration-none fw-bold" style="color: #2563eb;" asp-controller="Account" asp-action="Login">Đăng nhập</a>
        <a class="btn text-white rounded-pill px-4 fw-bold shadow-sm transition-all" style="background-color: #2563eb;" asp-controller="Account" asp-action="Register">Đăng ký</a>
    </div>
}
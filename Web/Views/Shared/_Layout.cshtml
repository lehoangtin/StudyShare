@using Microsoft.AspNetCore.Identity
@using StudyShare.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="vi">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyShare</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Outfit:wght@700&display=swap" rel="stylesheet" />
    
    <style>
        :root {
            --bg-blue: #f0f7ff;
            --dot-color: #cbd5e1;
            --main-blue: #2563eb;
            --text-dark: #0f172a;
            --nav-height: 85px;
        }

        body {
            background-color: var(--bg-blue) !important;
            /* HỌA TIẾT CHẤM BI TOÀN TRANG */
            background-image: radial-gradient(var(--dot-color) 1.2px, transparent 1.2px) !important;
            background-size: 25px 25px !important;
            background-attachment: fixed !important;
            color: var(--text-dark);
            font-family: 'Inter', sans-serif;
            margin: 0;
            -webkit-font-smoothing: antialiased;
        }

        /* NAVBAR KHUNG TRÊN */
        .main-header {
            height: var(--nav-height);
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid #e2e8f0;
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 1000;
            display: flex;
            align-items: center;
        }

        .nav-container {
            width: 100%;
            max-width: 1600px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
        }

        .logo-brand {
            font-family: 'Outfit', sans-serif;
            font-size: 24px;
            font-weight: 700;
            color: var(--main-blue);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .nav-links {
            display: flex;
            gap: 5px;
            align-items: center;
        }

        /* STYLE ICON & CHỮ TRONG MENU */
        .nav-custom-link {
            padding: 10px 15px;
            border-radius: 12px;
            color: #64748b;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .nav-custom-link i {
            font-size: 1.25rem;
            color: var(--main-blue);
        }

        .nav-custom-link:hover {
            background: #f1f5f9;
            color: var(--main-blue);
        }

        .nav-custom-link.active {
            background: var(--main-blue);
            color: #ffffff !important;
        }

        .nav-custom-link.active i {
            color: #ffffff;
        }

        /* AUTH BUTTONS */
        .btn-register-header {
            background: var(--main-blue);
            color: white !important;
            font-weight: 700;
            padding: 10px 22px;
            border-radius: 12px;
            box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
            text-decoration: none;
        }

        /* ===== CSS DROPDOWN ADMIN ===== */
        .admin-drop-item {
            font-weight: 600;
            color: #475569;
            padding: 10px 15px;
            border-radius: 8px;
            transition: all 0.2s ease;
            margin-bottom: 2px;
        }

        .admin-drop-item:hover {
            background-color: #f1f5f9;
            color: #2563eb;
            transform: translateX(4px);
        }

        .admin-drop-item.text-danger:hover {
            background-color: #fee2e2 !important;
            color: #ef4444 !important;
        }

        .dropdown-menu {
            animation: slideIn 0.2s ease-out;
        }

        @@keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .main-content {
            margin-top: var(--nav-height);
            padding: 40px 0;
        }

        .content-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .page-title-bold {
            font-weight: 800 !important;
            color: var(--text-dark);
            letter-spacing: -0.5px;
        }
    </style>
</head>
<body>

    <header class="main-header shadow-sm">
        <div class="nav-container">
            <button class="btn border-0 d-xl-none fs-3 text-primary p-0 me-3" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileMenu">
                <i class="bi bi-list"></i>
            </button>

            <a class="logo-brand" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-intersect"></i> StudyShare
            </a>

            <nav class="nav-links d-none d-xl-flex ms-4 me-auto">
                <a class="nav-custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" 
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i> Thư viện
                </a>
                
                <a class="nav-custom-link" asp-area="User" asp-controller="Chat" asp-action="Index">
                    <i class="bi bi-cpu-fill"></i> Trợ lí AI
                </a>
                
                <a class="nav-custom-link" asp-area="User" asp-controller="Question" asp-action="Index">
                    <i class="bi bi-chat-square-text-fill"></i> Thảo luận
                </a>
                
                <a class="nav-custom-link" asp-area="User" asp-controller="Ranking" asp-action="Index">
                    <i class="bi bi-trophy-fill"></i> Bảng vàng
                </a>

                @if (SignInManager.IsSignedIn(User))
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <div class="dropdown">
                            <a class="nav-custom-link dropdown-toggle ms-2" href="#" role="button" id="adminMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false" 
                               style="background-color: #eff6ff; color: #2563eb;">
                                <i class="bi bi-shield-lock-fill"></i> Quản trị
                            </a>
                            
                            <ul class="dropdown-menu shadow-lg border-0 rounded-4 mt-3 p-2" aria-labelledby="adminMenuDropdown" style="min-width: 240px;">
                                <li><div class="dropdown-header text-uppercase fw-bold text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Menu Quản Trị</div></li>
                                <li><a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Home" asp-action="Index"><i class="bi bi-speedometer2 me-2 text-primary"></i> Dashboard</a></li>
                                <li><a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="User" asp-action="Index"><i class="bi bi-people-fill me-2 text-secondary"></i> Người dùng</a></li>
                                <li><a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Document" asp-action="Index"><i class="bi bi-file-earmark-text-fill me-2 text-secondary"></i> Tài liệu</a></li>
                                <li><a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Question" asp-action="Index"><i class="bi bi-chat-square-dots-fill me-2" style="color: #0ea5e9;"></i> Thảo luận</a></li>
                                <li><a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Answer" asp-action="Index"><i class="bi bi-reply-all-fill me-2" style="color: #8b5cf6;"></i> Bình luận</a></li>
                                <li><a class="dropdown-item admin-drop-item" asp-area="Admin" asp-controller="Category" asp-action="Index"><i class="bi bi-tags-fill me-2 text-secondary"></i> Danh mục</a></li>
                                <li><hr class="dropdown-divider my-2"></li>
                                <li><a class="dropdown-item admin-drop-item text-danger fw-bold" asp-area="Admin" asp-controller="User" asp-action="PendingReports" style="background-color: #fef2f2;"><i class="bi bi-flag-fill me-2"></i> Báo cáo vi phạm</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="nav-custom-link ms-2" asp-area="User" asp-controller="Document" asp-action="Create">
                            <i class="bi bi-cloud-arrow-up-fill"></i> Tải lên
                        </a>
                    }
                }
            </nav>

            <div class="auth-group d-flex align-items-center gap-3 ms-auto">
                @if (!SignInManager.IsSignedIn(User))
                {
                    <a class="nav-custom-link d-none d-sm-flex" asp-area="" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-person-circle"></i> Đăng nhập
                    </a>
                    <a class="btn-register-header" asp-area="" asp-controller="Account" asp-action="Register">
                        Đăng ký ngay
                    </a>
                }
                else
                {
                    <partial name="_LoginPartial" />
                }
            </div>
        </div>
    </header>

    <div class="offcanvas offcanvas-start" tabindex="-1" id="mobileMenu" aria-labelledby="mobileMenuLabel">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold text-primary" id="mobileMenuLabel">
                <i class="bi bi-intersect"></i> StudyShare
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column gap-2">
            <a class="nav-custom-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">
                <i class="bi bi-grid-1x2-fill"></i> Thư viện
            </a>
            <a class="nav-custom-link" asp-area="User" asp-controller="Chat" asp-action="Index">
                <i class="bi bi-cpu-fill"></i> Trợ lí AI
            </a>
            <a class="nav-custom-link" asp-area="User" asp-controller="Question" asp-action="Index">
                <i class="bi bi-chat-square-text-fill"></i> Thảo luận
            </a>
            <a class="nav-custom-link" asp-area="User" asp-controller="Ranking" asp-action="Index">
                <i class="bi bi-trophy-fill"></i> Bảng vàng
            </a>

            @if (SignInManager.IsSignedIn(User))
            {
                <hr class="my-2 text-muted" />
                @if (User.IsInRole("Admin"))
                {
                    <span class="text-uppercase fw-bold text-muted ps-3 mb-1" style="font-size: 0.75rem; letter-spacing: 1px;">Quản Trị</span>
                    <a class="nav-custom-link" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard Admin
                    </a>
                    <a class="nav-custom-link text-danger" asp-area="Admin" asp-controller="User" asp-action="PendingReports">
                        <i class="bi bi-flag-fill text-danger"></i> Báo cáo vi phạm
                    </a>
                }
                else
                {
                    <a class="nav-custom-link" asp-area="User" asp-controller="Document" asp-action="Create" style="background-color: #eff6ff;">
                        <i class="bi bi-cloud-arrow-up-fill"></i> Tải tài liệu lên
                    </a>
                }
            }
        </div>
    </div>
    <main class="main-content">
        <div class="content-container">
            
           @if (TempData["Success"] != null || TempData["success"] != null || TempData["SuccessMessage"] != null)
{
    var successMsg = (TempData["Success"] ?? TempData["success"] ?? TempData["SuccessMessage"])?.ToString();
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'success',
                // Json.Serialize giúp tự động thêm ngoặc kép và fix lỗi chứa ký tự đặc biệt
                title: @Html.Raw(Json.Serialize(successMsg)),
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                background: '#f0fdf4',
                color: '#166534'
            });
        });
    </script>
}

@if (TempData["Error"] != null || TempData["error"] != null || TempData["ErrorMessage"] != null)
{
    var errorMsg = (TempData["Error"] ?? TempData["error"] ?? TempData["ErrorMessage"])?.ToString();
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            Swal.fire({
                toast: true,
                position: 'top-end',
                icon: 'error',
                title: @Html.Raw(Json.Serialize(errorMsg)),
                showConfirmButton: false,
                timer: 4000,
                timerProgressBar: true,
                background: '#fef2f2',
                color: '#991b1b'
            });
        });
    </script>
}
            
            @RenderBody()
        </div>
    </main>

<footer class="modern-footer">
    <div class="container">
        <div class="row mb-5">
            <div class="col-lg-5 mb-4 mb-lg-0 pe-lg-5">
                <h3 class="footer-title" style="font-family: 'Outfit', sans-serif;">
                    <i class="bi bi-intersect text-primary me-2"></i>StudyShare
                </h3>
                <p class="mb-4" style="line-height: 1.8; color: #cbd5e1;">
                    Hệ thống chia sẻ tài liệu và thảo luận học tập trực tuyến. Nơi kết nối tri thức, hỗ trợ sinh viên Bách Khoa và cộng đồng IT cùng nhau phát triển.
                </p>
                <div class="d-flex gap-3">
                    <a href="#" class="social-icon"><i class="bi bi-facebook"></i></a>
                    <a href="https://github.com/lehoangtin/StudyShare" class="social-icon"><i class="bi bi-github"></i></a>
                    <a href="#" class="social-icon"><i class="bi bi-discord"></i></a>
                </div>
            </div>

            <div class="col-lg-3 col-md-6 mb-4 mb-md-0">
                <h5 class="footer-title">Khám Phá</h5>
                <a asp-area="" asp-controller="Home" asp-action="Index" class="footer-link"><i class="bi bi-caret-right-fill me-2 small"></i> Thư viện tài liệu</a>
                <a asp-area="User" asp-controller="Chat" asp-action="Index" class="footer-link"><i class="bi bi-caret-right-fill me-2 small"></i> Trợ lý AI</a>
                <a asp-area="User" asp-controller="Question" asp-action="Index" class="footer-link"><i class="bi bi-caret-right-fill me-2 small"></i> Thảo luận cộng đồng</a>
                <a asp-area="User" asp-controller="Ranking" asp-action="Index" class="footer-link"><i class="bi bi-caret-right-fill me-2 small"></i> Bảng vàng</a>
            </div>

            <div class="col-lg-4 col-md-6">
                <h5 class="footer-title">Thông Tin Đồ Án</h5>
                <div class="d-flex align-items-start mb-3">
                    <i class="bi bi-geo-alt-fill text-primary fs-5 me-3 mt-1"></i>
                    <span style="color: #cbd5e1;">Đại học Bách khoa Đà Nẵng<br />Khoa Công nghệ thông tin</span>
                </div>
                <div class="d-flex align-items-center mb-3">
                    <i class="bi bi-laptop text-primary fs-5 me-3"></i>
                    <span style="color: #cbd5e1;">Đồ án Học phần PBL3</span>
                </div>
                <div class="d-flex align-items-center">
                    <i class="bi bi-envelope-fill text-primary fs-5 me-3"></i>
                    <span style="color: #cbd5e1;">nhom4.studyshare@gmail.com</span>
                </div>
            </div>
        </div>
        
        <hr style="border-color: rgba(255,255,255,0.1);">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center pt-3 pb-2">
            <p class="mb-2 mb-md-0 small" style="color: #94a3b8;">
                &copy; 2026 <b>StudyShare</b>. Phát triển bởi Nhóm 4 (Tín, Toàn, Minh, Dương).
            </p>
            <div class="small" style="color: #94a3b8;">
                <span>Phiên bản 1.0.0</span>
            </div>
        </div>
    </div>
</footer>
    <button id="btnBackToTop" class="btn text-white rounded-circle shadow-lg" style="background-color: var(--main-blue); position: fixed; bottom: 40px; right: 40px; width: 50px; height: 50px; display: none; z-index: 999; transition: all 0.3s ease; border: 2px solid white;">
    <i class="bi bi-chevron-up fs-5"></i>
</button>

<script>
    // Logic ẩn/hiện và cuộn mượt cho nút Back to Top
    let btnTop = document.getElementById("btnBackToTop");
    window.onscroll = function () {
        if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
            btnTop.style.display = "block";
            btnTop.style.opacity = "1";
        } else {
            btnTop.style.opacity = "0";
            setTimeout(() => { if(btnTop.style.opacity == "0") btnTop.style.display = "none"; }, 300);
        }
    };
    btnTop.addEventListener("click", function() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
    });
</script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* --- LOGIC MODAL BANNED --- *@
    @if (User.Identity.IsAuthenticated)
    {
        var currentUser = await UserManager.GetUserAsync(User);
        if (currentUser != null && (currentUser.WarningCount >= 3 || currentUser.IsBanned))
        {
            <div class="modal fade" id="violationModal" data-bs-backdrop="static">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content border-0 shadow-lg rounded-5">
                        <div class="modal-body text-center py-5">
                            <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem"></i>
                            <h3 class="fw-bold mt-3">TÀI KHOẢN BỊ KHÓA</h3>
                            <p class="text-muted">Tài khoản vi phạm chính sách cộng đồng.</p>
                            <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="btn btn-danger rounded-pill px-5">ĐĂNG XUẤT</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    new bootstrap.Modal(document.getElementById('violationModal')).show();
                });
            </script>
        }
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@model StudyShare.DTOs.Responses.DocumentResponse
@using System.Security.Claims
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Thư viện</a></li>
            <li class="breadcrumb-item active">@Model.CategoryName</li>
        </ol>
    </nav>

    <div class="row mt-3">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h3 class="fw-bold text-primary">@Model.Title</h3>
                    <hr />
                    <div class="bg-light p-3 rounded-3 mb-3">
                        <h6 class="fw-bold text-dark mb-2"><i class="bi bi-card-text text-primary me-1"></i> Mô tả tài liệu:</h6>
                        <div class="text-secondary" style="font-size: 0.95rem; white-space: pre-wrap; max-height: 200px; overflow-y: auto;">@(string.IsNullOrWhiteSpace(Model.Description) ? "Không có mô tả chi tiết." : Model.Description)</div>
                    </div>
                    
                    <p class="mb-2"><i class="bi bi-person-circle me-2"></i><strong>Người đăng:</strong> @Model.AuthorName</p>
                    <p class="mb-2"><i class="bi bi-calendar3 me-2"></i><strong>Ngày đăng:</strong> @Model.UploadDate.ToString("dd/MM/yyyy")</p>
                    <p class="mb-2"><i class="bi bi-eye me-2"></i><strong>Lượt xem:</strong> <span class="badge bg-secondary">@Model.Views</span></p>
                    
                    <div class="d-grid gap-2 mt-4">
                        @* TẢI XUỐNG - GỌI ACTION TRỪ ĐIỂM *@
                        <a asp-area="User" asp-controller="Document" asp-action="Download" asp-route-id="@Model.Id" 
                           class="btn btn-success" onclick="return confirm('Bạn sẽ bị trừ 10 điểm để tải. Tiếp tục?')">
                            <i class="bi bi-download me-1"></i> Tải xuống (10đ)
                        </a>

                        @* NÚT LƯU / BỎ LƯU TÀI LIỆU (Dùng chung hàm ToggleSave) *@
                        @* NÚT LƯU / BỎ LƯU TÀI LIỆU *@
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            @if (ViewBag.IsSaved == true)
                            {
                                <form asp-area="User" asp-controller="Document" asp-action="UnsaveDocument" method="post">
                                    <input type="hidden" name="docId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-outline-danger w-100 fw-bold">
                                        <i class="bi bi-bookmark-x-fill me-1"></i> Bỏ lưu tài liệu
                                    </button>
                                </form>
                            }
                            else
                            {
                                <form asp-area="User" asp-controller="Document" asp-action="SaveDocument" method="post">
                                    <input type="hidden" name="docId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-primary w-100 fw-bold">
                                        <i class="bi bi-bookmark-plus me-1"></i> Lưu tài liệu
                                    </button>
                                </form>
                            }
                        }


                        @* 🔥 XOÁ TÀI LIỆU (CỦA CHỦ SỞ HỮU) *@
                        @if (User?.Identity?.IsAuthenticated == true && Model.UserId == User.FindFirstValue(ClaimTypes.NameIdentifier))
                        {
                            <form asp-area="User" asp-controller="Document" asp-action="DeleteDocument" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Xóa vĩnh viễn tài liệu này?')">
                                <button type="submit" class="btn btn-danger w-100 mt-2">
                                    <i class="bi bi-trash me-1"></i> Xóa tài liệu của tôi
                                </button>
                            </form>
                        }
                        
                        <a asp-action="Index" class="btn btn-light border mt-2">Quay lại thư viện</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0" style="height: 800px;">
                <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-eye me-2"></i> Xem trước tài liệu</span>
                    <small>@Model.FileName</small>
                </div>
                <div class="card-body p-0">
                    @if (Model.FileType.Contains("pdf"))
                    {
                        <iframe src="@Model.FilePath#toolbar=0" width="100%" height="100%" style="border: none;"></iframe>
                    }
                    else if (Model.FileType.Contains("image"))
                    {
                        <div class="text-center p-3 h-100 d-flex align-items-center bg-light">
                            <img src="@Model.FilePath" class="img-fluid rounded mx-auto d-block shadow-sm" alt="Preview" style="max-height: 100%;" />
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 h-100 d-flex flex-column justify-content-center bg-light">
                            <i class="bi bi-file-earmark-zip text-warning" style="font-size: 5rem;"></i>
                            <h4 class="mt-3">Định dạng file này không hỗ trợ xem trực tuyến</h4>
                            <p class="text-muted">Vui lòng nhấn nút "Tải xuống" ở bên trái để xem nội dung.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
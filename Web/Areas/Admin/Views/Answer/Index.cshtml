@model IEnumerable<StudyShare.Models.Answer>
@{
    ViewData["Title"] = "Quản lý Bình luận";
}

<div class="container-fluid py-4" style="min-height: 100vh;">
    <div class="row g-4">
        <div class="col-xl-3 col-lg-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-xl-9 col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white pt-4 pb-3 border-bottom-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <h4 class="fw-bold text-primary mb-3 mb-md-0">
                        <i class="bi bi-chat-left-text me-2"></i>Quản lý Bình luận
                    </h4>

                    <ul class="nav nav-pills bg-light p-1 rounded-pill shadow-sm" id="answerTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active rounded-pill fw-bold px-4 transition-all" id="all-tab" data-bs-toggle="tab" data-bs-target="#all-pane" type="button" role="tab">
                                Tất cả bình luận
                                @if (Model != null && Model.Any()) {
                                    <span class="badge bg-primary rounded-pill ms-1">@Model.Count()</span>
                                }
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-0 border-top">
                    <div class="tab-content" id="answerTabsContent">
                        
                        <div class="tab-pane fade show active" id="all-pane" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 py-3 text-muted text-uppercase text-nowrap" style="width: 15%; font-size: 0.85rem;">Người đăng</th>
                                            <th class="py-3 text-muted text-uppercase" style="width: 40%; font-size: 0.85rem;">Nội dung bình luận</th>
                                            <th class="py-3 text-muted text-uppercase text-nowrap" style="width: 15%; font-size: 0.85rem;">Bài viết</th>
                                            <th class="py-3 text-muted text-uppercase text-nowrap" style="width: 15%; font-size: 0.85rem;">Thời gian</th>
                                            <th class="text-end pe-4 py-3 text-muted text-uppercase text-nowrap" style="width: 15%; font-size: 0.85rem;">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any())
                                        {
                                            foreach (var item in Model)
                                            {
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-primary-subtle text-primary rounded-circle p-2 me-3 text-center shadow-sm" style="width: 40px; height: 40px;">
                                                                <i class="bi bi-person-fill fs-5"></i>
                                                            </div>
                                                            <div class="fw-bold text-dark text-truncate" style="max-width: 120px;" title="@(item.User?.FullName ?? item.User?.UserName ?? "Ẩn danh")">
                                                                @(item.User?.FullName ?? item.User?.UserName ?? "Ẩn danh")
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="text-dark small" style="max-height: 60px; overflow-y: auto; padding-right: 10px;">
                                                            @item.Content
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <a href="/User/Question/Details/@item.QuestionId" target="_blank" class="badge bg-light text-secondary border text-decoration-none px-3 py-2 rounded-pill shadow-sm">
                                                            Bài #@item.QuestionId <i class="bi bi-box-arrow-up-right ms-1"></i>
                                                        </a>
                                                    </td>
                                                    <td>
                                                        <span class="text-muted small"><i class="bi bi-clock me-1"></i>@item.CreatedAt.ToString("dd/MM/yyyy")</span>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa bình luận này khỏi hệ thống?');">
                                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0;" title="Xóa">
                                                                <i class="bi bi-trash"></i>
                                                            </button>
                                                        </form>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="5" class="text-center py-5 border-0">
                                                    <i class="bi bi-chat-square-text display-4 opacity-50 d-block mb-3 text-muted"></i>
                                                    <h5 class="text-muted fw-bold">Trống</h5>
                                                    <p class="text-muted mb-0">Chưa có bình luận nào trên hệ thống.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            @if (TempData["Success"] != null)
            {
                <text>
                Swal.fire({ icon: 'success', title: 'Thành công!', text: '@Html.Raw(TempData["Success"])', timer: 3000 });
                </text>
            }
            @if (TempData["Error"] != null)
            {
                <text>
                Swal.fire({ icon: 'error', title: 'Lỗi!', text: '@Html.Raw(TempData["Error"])', timer: 3000 });
                </text>
            }
        });
    </script>
}
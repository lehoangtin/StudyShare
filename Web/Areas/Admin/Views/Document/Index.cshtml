@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>
@{
    ViewData["Title"] = "Quản lý tài liệu";
}

<div class="container mt-4 mb-5">
    <div class="row">
        <div class="col-md-3 mb-4">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            @* @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            } *@

            <div class="card shadow-sm border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white pt-4 pb-3 border-bottom-0 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <h4 class="fw-bold text-primary mb-3 mb-md-0">
                        <i class="bi bi-file-earmark-text me-2"></i>Quản lý kho tài liệu
                    </h4>

                    <ul class="nav nav-pills bg-light p-1 rounded-pill shadow-sm" id="documentTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active rounded-pill fw-bold px-4 transition-all" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending-pane" type="button" role="tab">
                                Chờ duyệt 
                                @if (Model != null && Model.Count(d => !d.IsApproved) > 0) {
                                    <span class="badge bg-danger rounded-pill ms-1">@Model.Count(d => !d.IsApproved)</span>
                                }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link rounded-pill fw-bold text-secondary px-4 transition-all" id="approved-tab" data-bs-toggle="tab" data-bs-target="#approved-pane" type="button" role="tab">
                                Đã duyệt
                                @if (Model != null && Model.Count(d => d.IsApproved) > 0) {
                                    <span class="badge bg-success rounded-pill ms-1">@Model.Count(d => d.IsApproved)</span>
                                }
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-0 border-top">
                    <div class="tab-content" id="documentTabsContent">
                        
                        <!-- TAB CHỜ DUYỆT -->
                        <div class="tab-pane fade show active" id="pending-pane" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 py-3 text-muted text-uppercase text-nowrap" style="width: 40%; font-size: 0.85rem;">Tài liệu</th>
                                            <th class="py-3 text-muted text-uppercase text-nowrap" style="width: 20%; font-size: 0.85rem;">Người đăng</th>
                                            <th class="py-3 text-muted text-uppercase text-nowrap" style="width: 15%; font-size: 0.85rem;">Trạng thái</th>
                                            <th class="text-end pe-4 py-3 text-muted text-uppercase text-nowrap" style="width: 25%; font-size: 0.85rem;">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any(d => !d.IsApproved))
                                        {
                                            @foreach (var item in Model.Where(d => !d.IsApproved))
                                            {
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-light rounded p-2 me-3 text-center" style="width: 45px; height: 45px;">
                                                                <i class="bi bi-file-earmark-font fs-4 text-warning"></i>
                                                            </div>
                                                            <div>
                                                                <h6 class="fw-bold mb-1 text-dark text-truncate" style="max-width: 250px;" title="@item.Title">@item.Title</h6>
                                                                <small class="text-muted">@item.CategoryName • @item.FileType</small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td><span class="fw-medium text-dark">@item.AuthorName</span></td>
                                                    <td>
                                                        <span class="badge bg-warning-subtle text-warning border border-warning px-2 py-1"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt</span>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <div class="btn-group">
                                                            <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white rounded-pill px-3 me-2 shadow-sm fw-bold">
                                                                <i class="bi bi-search me-1"></i> Kiểm duyệt
                                                            </a>
                                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn tài liệu này?')">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0;" title="Xóa">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-5 border-0">
                                                    <i class="bi bi-check2-circle text-success" style="font-size: 3.5rem;"></i>
                                                    <h5 class="text-muted fw-bold mt-3">Tuyệt vời!</h5>
                                                    <p class="text-muted mb-0">Không có tài liệu nào đang chờ duyệt.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- TAB ĐÃ DUYỆT -->
                        <div class="tab-pane fade" id="approved-pane" role="tabpanel">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th class="ps-4 py-3 text-muted text-uppercase text-nowrap" style="width: 40%; font-size: 0.85rem;">Tài liệu</th>
                                            <th class="py-3 text-muted text-uppercase text-nowrap" style="width: 20%; font-size: 0.85rem;">Người đăng</th>
                                            <th class="py-3 text-muted text-uppercase text-nowrap" style="width: 15%; font-size: 0.85rem;">Trạng thái</th>
                                            <th class="text-end pe-4 py-3 text-muted text-uppercase text-nowrap" style="width: 25%; font-size: 0.85rem;">Hành động</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (Model != null && Model.Any(d => d.IsApproved))
                                        {
                                            @foreach (var item in Model.Where(d => d.IsApproved))
                                            {
                                                <tr>
                                                    <td class="ps-4 py-3">
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-light rounded p-2 me-3 text-center" style="width: 45px; height: 45px;">
                                                                <i class="bi bi-file-earmark-check fs-4 text-success"></i>
                                                            </div>
                                                            <div>
                                                                <h6 class="fw-bold mb-1 text-dark text-truncate" style="max-width: 250px;" title="@item.Title">@item.Title</h6>
                                                                <small class="text-muted">@item.CategoryName • @item.FileType</small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td><span class="fw-medium text-dark">@item.AuthorName</span></td>
                                                    <td>
                                                        <span class="badge bg-success-subtle text-success border border-success px-2 py-1"><i class="bi bi-check-circle me-1"></i> Đã duyệt</span>
                                                    </td>
                                                    <td class="text-end pe-4">
                                                        <div class="btn-group">
                                                            <a asp-action="Review" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 me-2 shadow-sm">
                                                                <i class="bi bi-eye me-1"></i> Xem chi tiết
                                                            </a>
                                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn tài liệu này?')">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-circle shadow-sm" style="width: 32px; height: 32px; padding: 0;" title="Xóa">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="4" class="text-center py-5 border-0">
                                                    <i class="bi bi-folder2-open display-4 opacity-50 d-block mb-3"></i>
                                                    <h5 class="text-muted fw-bold">Trống</h5>
                                                    <p class="text-muted mb-0">Kho tài liệu đã duyệt hiện đang trống.</p>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
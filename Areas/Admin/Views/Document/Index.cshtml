@model IEnumerable<StudyShare.ViewModels.DocumentViewModel>

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-3">
            @await Html.PartialAsync("_AdminSidebarPartial")
        </div>

        <div class="col-md-9">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white py-3">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="fw-bold text-primary mb-0">
                            <i class="bi bi-folder2-open me-2"></i>Quản lý tài liệu
                        </h4>
                        
                        <form asp-action="Index" method="get" class="d-flex shadow-sm rounded-pill overflow-hidden" style="width: 350px;">
                            <input type="hidden" name="status" value="@ViewBag.CurrentStatus" />
                            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                                   class="form-control border-0 px-3" placeholder="Tìm tên tài liệu, tác giả...">
                            <button type="submit" class="btn btn-primary px-3 border-0">
                                <i class="bi bi-search"></i>
                            </button>
                        </form>
                    </div>

                    <div class="nav nav-pills nav-fill bg-light p-1 rounded-3">
                        <a class="nav-link @(ViewBag.CurrentStatus == "all" ? "active bg-primary" : "text-secondary")" 
                           href="@Url.Action("Index", new { status = "all", searchString = ViewData["CurrentFilter"] })">
                            Tất cả
                        </a>
                        <a class="nav-link @(ViewBag.CurrentStatus == "pending" ? "active bg-warning text-dark" : "text-secondary")" 
                           href="@Url.Action("Index", new { status = "pending", searchString = ViewData["CurrentFilter"] })">
                            <i class="bi bi-clock-history me-1"></i> Chờ duyệt
                        </a>
                        <a class="nav-link @(ViewBag.CurrentStatus == "approved" ? "active bg-success" : "text-secondary")" 
                           href="@Url.Action("Index", new { status = "approved", searchString = ViewData["CurrentFilter"] })">
                            <i class="bi bi-check-all me-1"></i> Đã duyệt
                        </a>
                    </div>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Thông tin tài liệu</th>
                                    <th>Người đăng</th>
                                    <th class="text-center">Lượt xem</th>
                                    <th class="text-center">Trạng thái</th>
                                    <th class="text-end pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Any()) {
                                    foreach (var item in Model) {
                                        <tr>
                                            <td class="ps-4 py-3">
                                                <div class="d-flex align-items-center">
                                                    <div class="icon-box bg-blue-subtle text-primary rounded-3 p-2 me-3">
                                                        <i class="bi bi-file-earmark-pdf fs-4"></i>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold text-dark">@item.Title</div>
                                                        <small class="text-muted text-uppercase">@item.CategoryName • @item.FileType</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="fw-medium">@item.AuthorName</div>
                                                <small class="text-muted">@item.UploadDate.ToString("dd/MM/yyyy")</small>
                                            </td>
                                            <td class="text-center">
                                                <span class="badge rounded-pill bg-light text-dark border">
                                                    <i class="bi bi-eye me-1"></i> @item.Views
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                @if (item.IsApproved) {
                                                    <span class="badge bg-success-subtle text-success border border-success">Đã duyệt</span>
                                                } else {
                                                    <span class="badge bg-warning-subtle text-warning border border-warning">Đợi duyệt</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <div class="btn-group shadow-sm rounded-pill bg-white border p-1">
                                                    <a asp-action="Review" asp-route-id="@item.Id" 
                                                       class="btn btn-sm btn-link text-decoration-none @(item.IsApproved ? "text-primary" : "text-info fw-bold")">
                                                        <i class="bi @(item.IsApproved ? "bi-eye" : "bi-shield-check")"></i> 
                                                        @(item.IsApproved ? "Xem" : "Duyệt")
                                                    </a>
                                                    <button class="btn btn-sm btn-link text-danger border-start" 
                                                            onclick="confirmDelete(@item.Id)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                } else {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <p class="text-muted mb-0">Không tìm thấy tài liệu nào phù hợp.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-blue-subtle { background-color: #e7f1ff; }
    .nav-pills .nav-link { transition: all 0.3s ease; border-radius: 8px; }
    .table thead th { font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .icon-box { width: 42px; height: 42px; display: flex; align-items: center; justify-content: center; }
</style>
